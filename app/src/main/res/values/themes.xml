<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme; Compose drives actual UI styling via Material3. -->
    <style name="Theme.HRIS" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Android 12+ splash screen; falls back gracefully on API 26+. -->
    <style name="Theme.HRIS.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/launch_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/hris_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.HRIS</item>
    </style>
</resources>
